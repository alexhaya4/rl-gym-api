# Security
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://rl_gym:rl_gym@localhost:5432/rl_gym
# For local SQLite development use: sqlite+aiosqlite:///./rl_gym.db

# Redis
REDIS_URL=redis://localhost:6379

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Model Storage ("local" for filesystem, "s3" for S3/MinIO)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./models
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=rl-gym-models
# S3_ENDPOINT_URL=http://localhost:9000  # For MinIO compatibility

# Stripe (required for billing features)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_FREE_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# Tier Limits
FREE_TIER_MAX_EXPERIMENTS=5
FREE_TIER_MAX_ENVIRONMENTS=3
FREE_TIER_MAX_TIMESTEPS=50000
PRO_TIER_MAX_EXPERIMENTS=100
PRO_TIER_MAX_ENVIRONMENTS=20
PRO_TIER_MAX_TIMESTEPS=5000000

# CORS
ALLOWED_ORIGINS=http://localhost:3000
